---
interface Props {
  currentPath: string;
}

const { currentPath: _currentPath } = Astro.props;
---

<header class="sticky top-0 z-50 bg-slate-950/70 backdrop-blur-md border-b border-white/5">
  <div class="max-w-site mx-auto px-4 sm:px-6 py-4 flex justify-between items-center">
    <a href="/" aria-label="Retensiq home" class="flex-shrink-0">
      <img src="/images/logo.png" alt="Retensiq" class="h-7" width="120" height="28" />
    </a>

    <a
      href="https://app.retensiq.com/"
      rel="noopener noreferrer"
      class="text-body-sm text-white/60 hover:text-white transition-colors"
    >
      Login
    </a>
  </div>
</header>
