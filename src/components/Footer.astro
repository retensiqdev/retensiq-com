---
---

<footer class="py-14 border-t border-white/10">
  <div class="max-w-site mx-auto px-4 sm:px-6">

    <!-- Main footer grid -->
    <div class="grid grid-cols-2 gap-8 sm:grid-cols-4 lg:gap-12">

      <!-- Products -->
      <div>
        <h3 class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/40 mb-4">Products</h3>
        <ul class="space-y-2.5 text-body-sm text-white/55">
          <li><a href="/assess" class="hover:text-white transition-colors">Retensiq Assess</a></li>
          <li><a href="/prep" class="hover:text-white transition-colors">Retensiq Prep</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/40 mb-4">Company</h3>
        <ul class="space-y-2.5 text-body-sm text-white/55">
          <li><a href="/platform" class="hover:text-white transition-colors">Platform</a></li>
          <li><a href="/security" class="hover:text-white transition-colors">Security</a></li>
          <li>
            <a href="https://app.retensiq.com/" rel="noopener noreferrer" class="hover:text-white transition-colors">
              Login
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/40 mb-4">Legal</h3>
        <ul class="space-y-2.5 text-body-sm text-white/55">
          <li><a href="/legal/privacy" class="hover:text-white transition-colors">Privacy Policy</a></li>
          <li><a href="/legal/terms" class="hover:text-white transition-colors">Terms of Use</a></li>
          <li><a href="/legal/dpa" class="hover:text-white transition-colors">Data Processing Agreement</a></li>
          <li><a href="/legal/trust" class="hover:text-white transition-colors">Trust &amp; Safety</a></li>
        </ul>
      </div>

      <!-- Brand -->
      <div class="col-span-2 sm:col-span-1">
        <a href="/" aria-label="Retensiq home" class="inline-block mb-4">
          <img src="/images/logo.png" alt="Retensiq" class="h-7" width="120" height="28" />
        </a>
        <p class="text-caption text-white/40 leading-relaxed">
          A platform for developing, validating, and defending genuine understanding.
        </p>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-2 text-caption text-white/30">
      <p>© <span id="footer-year"></span> Retensiq. All rights reserved.</p>
    </div>

  </div>
</footer>

<script>
  const el = document.getElementById('footer-year');
  if (el) el.textContent = String(new Date().getFullYear());
</script>
