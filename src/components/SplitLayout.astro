---
/**
 * SplitLayout — two-column text + visual layout with responsive stacking
 *
 * Slots:
 *   default (left column) — text content
 *   visual  (right column) — illustration, mockup, or visual
 *
 * Props:
 *   reverse   — swap column order on desktop (visual left, text right)
 *   gap       — Tailwind gap class (default 'gap-12 lg:gap-16')
 *   align     — vertical alignment: 'start' | 'center' (default 'start')
 */
interface Props {
  reverse?: boolean;
  gap?: string;
  align?: 'start' | 'center';
  class?: string;
}

const {
  reverse = false,
  gap = 'gap-12 lg:gap-16',
  align = 'start',
  class: className = '',
} = Astro.props;
---

<div
  class:list={[
    'grid grid-cols-1 lg:grid-cols-2',
    gap,
    align === 'center' ? 'lg:items-center' : 'lg:items-start',
    className,
  ]}
>
  <div class:list={[reverse ? 'lg:order-2' : 'lg:order-1']}>
    <slot />
  </div>
  <div class:list={[reverse ? 'lg:order-1' : 'lg:order-2']}>
    <slot name="visual" />
  </div>
</div>
