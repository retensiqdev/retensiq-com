---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTAButton from '../components/CTAButton.astro';
import CTABlock from '../components/CTABlock.astro';
import FeatureCard from '../components/FeatureCard.astro';
import SplitLayout from '../components/SplitLayout.astro';
---

<BaseLayout
  title="Platform"
  description="Retensiq is built for how schools and institutions actually operate — FERPA-aware data handling, LMS integration with LTI authentication, role-based access controls, and institutional workflows designed for real classrooms."
  canonicalUrl="https://retensiq.com/platform"
>

  <!-- Hero -->
  <section class="relative overflow-hidden py-24 md:py-28 border-b border-white/10">
    <div class="pointer-events-none absolute -bottom-40 -right-40 w-[500px] h-[500px] bg-indigo-600/12 blur-3xl rounded-full" aria-hidden="true"></div>

    <div class="relative max-w-site mx-auto px-4 sm:px-6">
      <div class="max-w-prose-lg">
        <p class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/40 mb-6">Platform</p>
        <h1 class="text-page-hero font-semibold tracking-tight text-white leading-[1.08]">
          Built for how institutions actually operate.
        </h1>
        <p class="mt-5 text-body-lg text-white/60 leading-relaxed max-w-prose">
          Retensiq supports Assess and Prep on a shared platform foundation — FERPA-aware, LMS-integrated, and designed to meet the requirements of district procurement and IT governance.
        </p>
      </div>
    </div>
  </section>


  <!-- Privacy and FERPA -->
  <Section id="privacy">
    <SectionHeading
      eyebrow="Data Handling"
      heading="FERPA-aware by design."
      subheading="Retensiq is built to support education privacy expectations by limiting unnecessary student-data exposure and keeping educator review centered on submission-grounded evidence."
    />

    <div class="mt-10 grid gap-3 md:grid-cols-2 lg:grid-cols-3">
      <FeatureCard
        label="Minimal Data Collection"
        description="Assessment workflows collect only what is needed for comprehension review. Data use is scoped to the instructional context."
        dotColor="bg-indigo-400"
        dense={true}
      />
      <FeatureCard
        label="Privacy-Conscious Ingestion"
        description="Document processing pipelines include redaction stages to limit unnecessary exposure of sensitive content."
        dotColor="bg-blue-300"
        dense={true}
      />
      <FeatureCard
        label="Student Participation"
        description="Students can participate in assessments without requiring full registered accounts, reducing the data footprint by design."
        dotColor="bg-violet-400"
        dense={true}
      />
      <FeatureCard
        label="Policy Alignment"
        description="Workflow patterns are designed to align with district policy decisions around data governance and retention."
        dotColor="bg-indigo-300"
        dense={true}
      />
      <FeatureCard
        label="Data Processing Agreement"
        description="DPA acceptance is handled during onboarding. Available for review before procurement decisions."
        dotColor="bg-blue-400"
        dense={true}
      >
        <a href="/legal/dpa" class="mt-3 inline-flex text-caption text-white/50 hover:text-white/80 transition-colors underline underline-offset-2">
          View DPA
        </a>
      </FeatureCard>
      <FeatureCard
        label="Educator-Controlled Workflows"
        description="Educators control assessment creation, student participation, and the review process. No autonomous student data collection."
        dotColor="bg-emerald-400"
        dense={true}
      />
    </div>
  </Section>


  <!-- LMS integration -->
  <Section id="lms" border={true}>
    <SplitLayout align="center">
      <div>
        <SectionHeading
          eyebrow="LMS Integration"
          heading="Fits established LMS workflows."
          subheading="Retensiq provides direct LMS plugins that integrate within existing institutional workflows, with authentication handled through LTI standards."
        />

        <ul class="mt-8 space-y-4">
          <li class="flex items-start gap-3">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-emerald-400 flex-shrink-0" aria-hidden="true"></span>
            <div class="text-body-sm">
              <span class="font-medium text-white/90">Moodle available now.</span>
              <span class="text-white/60"> Direct plugin support for Moodle-centered teaching operations, accessible within the LMS environment.</span>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-blue-400 flex-shrink-0" aria-hidden="true"></span>
            <div class="text-body-sm">
              <span class="font-medium text-white/90">LTI-authenticated access.</span>
              <span class="text-white/60"> Authentication follows LTI standards, aligning with established institutional LMS deployment practices.</span>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-violet-400 flex-shrink-0" aria-hidden="true"></span>
            <div class="text-body-sm">
              <span class="font-medium text-white/90">Teacher-first design.</span>
              <span class="text-white/60"> Assess workflows launch from within the LMS context teachers already use, minimizing context switching.</span>
            </div>
          </li>
        </ul>
      </div>

      <div slot="visual" class="rounded-2xl border border-white/10 bg-white/[0.04] p-6 shadow-card">
        <p class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/40 mb-4">Integration Summary</p>
        <div class="space-y-3">
          {[
            { label: 'Authentication', value: 'LTI 1.3' },
            { label: 'Supported LMS', value: 'Moodle (more in progress)' },
            { label: 'Deployment', value: 'Plugin-based, IT-controlled rollout' },
            { label: 'Access model', value: 'Teacher-initiated, educator-controlled' },
          ].map(({ label, value }) => (
            <div class="flex justify-between text-body-sm border-b border-white/5 pb-3 last:border-0 last:pb-0">
              <span class="text-white/45">{label}</span>
              <span class="text-white/80 font-medium">{value}</span>
            </div>
          ))}
        </div>
      </div>
    </SplitLayout>
  </Section>


  <!-- Accessibility and accommodations -->
  <Section id="accessibility" border={true}>
    <SectionHeading
      eyebrow="Instructional Access"
      heading="Flexible for diverse learners."
      subheading="Retensiq is designed to support educators working with multilingual learners, students with accommodations, and varied instructional contexts."
    />

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-7 shadow-card">
        <h3 class="text-body font-semibold text-white mb-3">ESL and Language Flexibility</h3>
        <p class="text-body-sm text-white/60 leading-relaxed">
          Text and voice response modes give educators the flexibility to match assessment format to student communication needs. Educators retain control over mode selection.
        </p>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-7 shadow-card">
        <h3 class="text-body font-semibold text-white mb-3">IEP-Informed Practice</h3>
        <p class="text-body-sm text-white/60 leading-relaxed">
          Short assessment length, teacher-controlled pacing, and flexible delivery options allow educators to adapt workflows alongside existing student support plans.
        </p>
      </div>
    </div>
  </Section>


  <!-- Platform FAQ -->
  <Section id="platform-faq" border={true} tight={true}>
    <SectionHeading
      eyebrow="Common Questions"
      heading="For procurement and IT teams."
      maxWidth="max-w-prose-lg"
    />

    <div class="mt-10 max-w-prose-lg space-y-2.5">
      {[
        {
          q: 'Is Retensiq an AI detector?',
          a: 'No. Retensiq is built for learning validation and comprehension assessment — not detection scoring. The platform focuses on demonstrated understanding through oral defense and articulation, not submission analysis.',
        },
        {
          q: 'How does Retensiq handle student data under FERPA?',
          a: 'Retensiq follows FERPA-aware workflows by limiting data collection to what is necessary for comprehension review, supporting educator-controlled student participation, and providing a Data Processing Agreement for district review.',
        },
        {
          q: 'What LMS integrations are available?',
          a: 'Moodle is available now via a direct LTI-authenticated plugin. Additional integrations are in development.',
        },
        {
          q: 'Can Retensiq support students with IEPs or language accommodations?',
          a: 'Yes. Text and voice response modes, short assessment lengths, and teacher-controlled delivery options are designed to give educators flexibility alongside existing support plans.',
        },
        {
          q: 'Where is data hosted?',
          a: 'Retensiq infrastructure runs on AWS. For detailed security and data handling information, review the Security page.',
          link: { href: '/security', label: 'View Security overview' },
        },
      ].map(({ q, a, link }) => (
        <details class="group rounded-2xl border border-white/10 bg-white/[0.04] p-5">
          <summary class="cursor-pointer font-semibold text-body-sm text-white flex justify-between items-center select-none list-none">
            {q}
            <span class="text-white/40 group-open:rotate-45 transition-transform ml-4 flex-shrink-0 text-lg leading-none">+</span>
          </summary>
          <p class="mt-3 text-body-sm text-white/60 leading-relaxed">{a}</p>
          {link && (
            <a href={link.href} class="mt-2 inline-flex text-caption text-white/50 hover:text-white/80 transition-colors underline underline-offset-2">
              {link.label}
            </a>
          )}
        </details>
      ))}
    </div>
  </Section>


  <!-- CTA -->
  <Section id="platform-cta" border={true}>
    <CTABlock
      heading="Ready to evaluate fit for your institution?"
      subheading="Request a demo or review the full security and compliance documentation."
      accent="neutral"
    >
      <CTAButton href="https://app.retensiq.com/request-invite" variant="primary">
        Request a Demo
      </CTAButton>
      <CTAButton href="/security" variant="secondary">
        Security Overview
      </CTAButton>
    </CTABlock>
  </Section>

</BaseLayout>
