---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTAButton from '../components/CTAButton.astro';
import CTABlock from '../components/CTABlock.astro';
import FeatureCard from '../components/FeatureCard.astro';
import SplitLayout from '../components/SplitLayout.astro';
import ProductEyebrow from '../components/ProductEyebrow.astro';

const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Retensiq Assess',
  applicationCategory: 'EducationApplication',
  operatingSystem: 'Web',
  description:
    'Institutional comprehension validation through oral defense, reasoning evaluation, and articulation-based assessment.',
  url: 'https://retensiq.com/assess',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
---

<BaseLayout
  title="Retensiq Assess"
  description="Retensiq Assess gives institutions visibility into genuine student understanding through oral defense, reasoning evaluation, and articulation-based comprehension validation."
  canonicalUrl="https://retensiq.com/assess"
  jsonLd={softwareAppSchema}
>

  <!-- ─────────────────────────────────────────────────────────────────────────
       HERO — institutional tone: structured, restrained, analytical
  ───────────────────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden py-24 md:py-32 border-b border-white/12">

    <!-- Cooler ambient glow — top-right, institutional blue -->
    <div class="pointer-events-none absolute -top-40 -right-40 w-[480px] h-[480px] bg-blue-700/18 blur-3xl rounded-full" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_60%_40%_at_80%_10%,rgba(37,99,235,0.08),transparent)]" aria-hidden="true"></div>

    <div class="relative max-w-site mx-auto px-4 sm:px-6">
      <div class="grid gap-16 lg:grid-cols-2 lg:items-center">

        <!-- Left: text + CTAs -->
        <div>
          <ProductEyebrow product="assess" />

          <h1 class="text-page-hero font-semibold tracking-tight text-white leading-[1.08]">
            Institutional visibility<br />
            <span class="text-white/55">into genuine understanding.</span>
          </h1>

          <p class="mt-6 text-body-lg text-white/60 leading-relaxed max-w-prose">
            Retensiq Assess helps institutions validate comprehension through oral defense, reasoning evaluation, and articulation-based assessment — not just what students submit.
          </p>

          <div class="mt-8 flex flex-wrap items-center gap-3">
            <CTAButton href="https://app.retensiq.com/request-invite" variant="primary">
              Request a Demo
            </CTAButton>
            <CTAButton href="/platform" variant="secondary">
              Explore the Platform
            </CTAButton>
          </div>
        </div>

        <!-- Right: evaluation-flow SVG (desktop only) -->
        <div class="hidden lg:flex items-center justify-center" aria-hidden="true">
          <div class="assess-visual w-full max-w-sm">
            <svg viewBox="0 0 320 380" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
              <line x1="40" y1="48" x2="40" y2="332"
                stroke="rgba(255,255,255,0.08)" stroke-width="1.5" stroke-dasharray="4 4"
                class="assess-spine" />

              <g class="assess-stage assess-stage-1">
                <circle cx="40" cy="48" r="6" fill="rgba(96,165,250,0.75)" />
                <rect x="64" y="28" width="232" height="42" rx="8"
                  fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
                <text x="80" y="44" fill="rgba(255,255,255,0.90)" font-size="11" font-weight="600" font-family="Inter,system-ui,sans-serif">Submission &amp; Context</text>
                <text x="80" y="59" fill="rgba(255,255,255,0.42)" font-size="9.5" font-family="Inter,system-ui,sans-serif">Work submitted with supporting research.</text>
              </g>
              <circle cx="40" cy="116" r="2.5" fill="rgba(255,255,255,0.15)" class="assess-dot" />

              <g class="assess-stage assess-stage-2">
                <circle cx="40" cy="144" r="6" fill="rgba(139,92,246,0.75)" />
                <rect x="64" y="124" width="232" height="42" rx="8"
                  fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
                <text x="80" y="140" fill="rgba(255,255,255,0.90)" font-size="11" font-weight="600" font-family="Inter,system-ui,sans-serif">Reasoning Evaluation</text>
                <text x="80" y="155" fill="rgba(255,255,255,0.42)" font-size="9.5" font-family="Inter,system-ui,sans-serif">Structured follow-up questions generated.</text>
              </g>
              <circle cx="40" cy="212" r="2.5" fill="rgba(255,255,255,0.15)" class="assess-dot" />

              <g class="assess-stage assess-stage-3">
                <circle cx="40" cy="240" r="6" fill="rgba(96,165,250,0.55)" />
                <rect x="64" y="220" width="232" height="42" rx="8"
                  fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
                <text x="80" y="236" fill="rgba(255,255,255,0.90)" font-size="11" font-weight="600" font-family="Inter,system-ui,sans-serif">Oral Defense &amp; Articulation</text>
                <text x="80" y="251" fill="rgba(255,255,255,0.42)" font-size="9.5" font-family="Inter,system-ui,sans-serif">Students explain, defend, and demonstrate.</text>
              </g>
              <circle cx="40" cy="308" r="2.5" fill="rgba(255,255,255,0.15)" class="assess-dot" />

              <g class="assess-stage assess-stage-4">
                <circle cx="40" cy="336" r="6" fill="rgba(52,211,153,0.65)" />
                <rect x="64" y="316" width="232" height="42" rx="8"
                  fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
                <text x="80" y="332" fill="rgba(255,255,255,0.90)" font-size="11" font-weight="600" font-family="Inter,system-ui,sans-serif">Insight &amp; Visibility</text>
                <text x="80" y="347" fill="rgba(255,255,255,0.42)" font-size="9.5" font-family="Inter,system-ui,sans-serif">Educators receive structured evidence.</text>
              </g>
            </svg>
          </div>
        </div>

      </div>
    </div>
  </section>

  <style>
    .assess-stage {
      opacity: 0;
      animation: assess-appear 0.5s ease forwards;
    }
    .assess-stage-1 { animation-delay: 0.10s; }
    .assess-stage-2 { animation-delay: 0.35s; }
    .assess-stage-3 { animation-delay: 0.60s; }
    .assess-stage-4 { animation-delay: 0.85s; }

    .assess-dot {
      opacity: 0;
      animation: assess-appear 0.3s ease forwards;
    }
    .assess-stage-1 + .assess-dot { animation-delay: 0.28s; }
    .assess-stage-2 + .assess-dot { animation-delay: 0.53s; }
    .assess-stage-3 + .assess-dot { animation-delay: 0.78s; }

    @keyframes assess-appear {
      from { opacity: 0; transform: translateX(-6px); }
      to   { opacity: 1; transform: translateX(0); }
    }

    .assess-spine {
      stroke-dashoffset: 400;
      animation: assess-draw-spine 1.2s ease forwards 0.05s;
    }
    @keyframes assess-draw-spine {
      to { stroke-dashoffset: 0; }
    }
  </style>


  <!-- ─────────────────────────────────────────────────────────────────────────
       SECTION 2 — THE PROBLEM
       Frame the challenge as comprehension visibility, not AI detection
  ───────────────────────────────────────────────────────────────────────────── -->
  <Section id="the-problem" tight={true}>
    <SectionHeading
      eyebrow="The Problem"
      heading="Submissions alone do not prove understanding."
      subheading="Traditional systems evaluate outputs. Retensiq Assess evaluates how well students can explain, defend, and reason through their work."
    />

    <div class="mt-12 grid gap-8 lg:grid-cols-2 lg:items-start">

      <!-- Left: problem themes -->
      <div class="space-y-5">
        {[
          {
            label: 'Shallow comprehension visibility',
            description: 'Assignment completion and submission scores reveal what students produced — not how deeply they understand the material.',
          },
          {
            label: 'Reasoning is invisible',
            description: 'Output-only evaluation cannot distinguish a student who reasons carefully from one who cannot explain what they submitted.',
          },
          {
            label: 'Comprehension validation requires interaction',
            description: 'Understanding must be demonstrated — not just inferred from an artifact. Oral defense and articulation create evidence that submission review cannot.',
          },
          {
            label: 'Modern assessment demands more',
            description: 'As AI-generated content becomes easier to produce, demonstrated understanding becomes increasingly important to validate.',
          },
        ].map(({ label, description }) => (
          <div class="flex gap-4">
            <div class="flex-shrink-0 mt-1.5 h-1.5 w-1.5 rounded-full bg-blue-400/60"></div>
            <div>
              <div class="text-body-sm font-semibold text-white mb-1">{label}</div>
              <p class="text-body-sm text-white/55 leading-relaxed">{description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Right: contrast comparison card — denser institutional style -->
      <div class="rounded-2xl border border-white/12 bg-white/[0.04] p-6 shadow-card">
        <p class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/35 mb-5">What changes with Assess</p>
        <div class="grid grid-cols-2 gap-4">

          <div>
            <p class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/30 mb-4">Output-Only</p>
            <ul class="space-y-3">
              {[
                'Evaluates the submission',
                'Flags probability',
                'Reactive and binary',
                'No reasoning signal',
              ].map((item) => (
                <li class="flex items-start gap-2.5 text-body-sm text-white/40">
                  <span class="mt-1.5 h-1 w-1 rounded-full bg-white/20 flex-shrink-0" aria-hidden="true"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="rounded-xl border border-blue-300/20 bg-blue-500/8 p-4">
            <p class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-blue-300/70 mb-4">Understanding Validation</p>
            <ul class="space-y-3">
              {[
                'Evaluates the learner',
                'Measures comprehension',
                'Structured and auditable',
                'Reasoning made visible',
              ].map((item) => (
                <li class="flex items-start gap-2.5 text-body-sm text-white/75">
                  <span class="mt-1.5 h-1 w-1 rounded-full bg-blue-400/70 flex-shrink-0" aria-hidden="true"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

        </div>
      </div>

    </div>
  </Section>


  <!-- ─────────────────────────────────────────────────────────────────────────
       SECTION 3 — HOW ASSESS WORKS
       4-step workflow + conversational defense UI mockup
  ───────────────────────────────────────────────────────────────────────────── -->
  <Section id="how-it-works" border={true}>
    <SplitLayout align="start">
      <!-- Left: steps -->
      <div>
        <SectionHeading
          eyebrow="How It Works"
          heading="A structured path from submission to evidence."
          subheading="Assess integrates into existing workflows, giving institutions a practical, repeatable way to validate genuine comprehension."
        />

        <div class="mt-8 space-y-6">
          {[
            {
              step: '01',
              title: 'Submission & Context',
              body: 'Students submit work alongside supporting research, preparation notes, or source context — giving Assess the material needed to generate targeted comprehension checks.',
            },
            {
              step: '02',
              title: 'Reasoning & Articulation Evaluation',
              body: 'Assess generates structured follow-up questioning focused on reasoning, explanation, and comprehension. Adaptive prompts probe the depth and coherence of a student\'s understanding.',
            },
            {
              step: '03',
              title: 'Oral Defense & Interaction',
              body: 'Students demonstrate understanding through explanation, articulation, and oral defense workflows — responding to questions in a structured, reviewable format.',
            },
            {
              step: '04',
              title: 'Insight & Visibility',
              body: 'Educators gain meaningful visibility into comprehension quality, reasoning depth, and articulation confidence — with structured evidence to support fair, documented decisions.',
            },
          ].map(({ step, title, body }) => (
            <div class="flex gap-5">
              <div class="flex-shrink-0 w-8 h-8 rounded-xl bg-white/5 border border-white/12 flex items-center justify-center text-caption font-semibold text-white/40">
                {step}
              </div>
              <div>
                <div class="text-body-sm font-semibold text-white mb-1.5">{title}</div>
                <p class="text-body-sm text-white/60 leading-relaxed">{body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: oral defense session mockup -->
      <div slot="visual" class="rounded-2xl border border-blue-300/20 bg-blue-500/5 p-6 shadow-soft">
        <p class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/40 mb-4">Oral Defense Session</p>
        <div class="space-y-3 text-body-sm">

          <div class="rounded-xl border border-white/10 bg-white/[0.04] p-3.5">
            <p class="text-caption text-white/40 mb-1.5">Assess asks</p>
            <p class="text-white/80">Can you explain the central argument of your essay in your own words?</p>
          </div>

          <div class="rounded-xl border border-blue-300/20 bg-blue-500/10 p-3.5">
            <p class="text-caption text-white/40 mb-1.5">Student responds</p>
            <p class="text-white/70">My argument is that renewable energy adoption is constrained more by policy gaps than by technological readiness...</p>
          </div>

          <div class="rounded-xl border border-white/10 bg-white/[0.04] p-3.5">
            <p class="text-caption text-white/40 mb-1.5">Follow-up</p>
            <p class="text-white/80">What specific evidence from your research supports that claim about policy over technology?</p>
          </div>

          <div class="rounded-xl border border-blue-300/20 bg-blue-500/10 p-3.5">
            <p class="text-caption text-white/40 mb-1.5">Student responds</p>
            <p class="text-white/70">The IEA's 2023 report showed installation costs dropped 89% since 2010, while permitting timelines in the EU averaged 4.3 years...</p>
          </div>

        </div>

        <div class="mt-4 pt-4 border-t border-white/10">
          <p class="text-caption text-white/35 uppercase tracking-widest font-semibold mb-3">Articulation signals</p>
          <div class="space-y-2.5">
            {[
              { label: 'Argument Clarity', value: 84 },
              { label: 'Evidence Specificity', value: 91 },
              { label: 'Reasoning Depth', value: 77 },
            ].map(({ label, value }) => (
              <div>
                <div class="flex justify-between text-caption text-white/50 mb-1">
                  <span>{label}</span>
                  <span>{value}%</span>
                </div>
                <div class="h-1.5 bg-white/10 rounded-full overflow-hidden">
                  <div class="h-full bg-blue-400/65 rounded-full" style={`width: ${value}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </SplitLayout>
  </Section>


  <!-- ─────────────────────────────────────────────────────────────────────────
       SECTION 4 — ORAL DEFENSE & ARTICULATION
       Core differentiator — institutional credibility
  ───────────────────────────────────────────────────────────────────────────── -->
  <Section id="oral-defense" border={true}>
    <SplitLayout align="center" reverse={true}>
      <!-- Left (visual on desktop): defense review mockup -->
      <div slot="visual" class="rounded-2xl border border-blue-300/20 bg-blue-500/5 p-6 shadow-soft">

        <div class="rounded-xl border border-white/10 bg-slate-900/60 p-5 mb-4">
          <div class="flex items-center justify-between mb-4">
            <p class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/40">Defense Review</p>
            <span class="text-caption font-semibold text-blue-300/70 bg-blue-500/15 border border-blue-300/20 rounded-full px-2.5 py-0.5">In Progress</span>
          </div>

          <div class="space-y-3 text-body-sm mb-5">
            <div class="rounded-lg border border-white/8 bg-white/[0.04] p-3">
              <p class="text-caption text-white/35 mb-1">Prompt</p>
              <p class="text-white/75">How would your argument change if the primary evidence were disputed?</p>
            </div>
            <div class="rounded-lg border border-blue-300/15 bg-blue-500/8 p-3">
              <p class="text-caption text-white/35 mb-1">Response</p>
              <p class="text-white/65">If the IEA data were disputed, I'd need to rely on regional case studies — Germany and Denmark's transition timelines still support the policy gap thesis independently...</p>
            </div>
          </div>

          <div class="grid grid-cols-3 gap-2 pt-4 border-t border-white/10">
            {[
              { label: 'Adaptability', score: 'Strong' },
              { label: 'Source Use', score: 'Specific' },
              { label: 'Logic', score: 'Coherent' },
            ].map(({ label, score }) => (
              <div class="text-center">
                <div class="text-caption text-white/35 mb-1">{label}</div>
                <div class="text-caption font-semibold text-blue-300/80">{score}</div>
              </div>
            ))}
          </div>
        </div>

        <p class="text-caption text-white/35 leading-relaxed text-center">
          Structured evidence. Auditable record. Consistent format across every classroom.
        </p>
      </div>

      <!-- Right: narrative copy -->
      <div>
        <SectionHeading
          eyebrow="Core Differentiator"
          heading="Oral defense creates visibility into genuine understanding."
          subheading="Articulation reveals understanding in ways static submissions cannot. When students explain what they know, understanding becomes measurable."
        />

        <div class="mt-8 space-y-6">
          {[
            {
              label: 'Measure explanation, not just submission',
              description: 'Assess evaluates how confidently and accurately students can explain, defend, and reason through their work — creating evidence that goes beyond the artifact.',
            },
            {
              label: 'Structured conversational defense',
              description: 'The oral defense format is modeled on academic defense practice: structured, reviewable, and consistent across classrooms. Not interrogation — validated inquiry.',
            },
            {
              label: 'Articulation confidence as a learning signal',
              description: 'The clarity and confidence with which a student articulates an idea is itself meaningful data. Assess surfaces that signal in a structured, documented format.',
            },
          ].map(({ label, description }) => (
            <div class="flex gap-4">
              <div class="flex-shrink-0 mt-1.5 h-1.5 w-1.5 rounded-full bg-blue-400/70"></div>
              <div>
                <div class="text-body-sm font-semibold text-white mb-1">{label}</div>
                <p class="text-body-sm text-white/60 leading-relaxed">{description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </SplitLayout>
  </Section>


  <!-- ─────────────────────────────────────────────────────────────────────────
       SECTION 5 — DISTRICT INSIGHTS & VISIBILITY
       Denser grid — institutional information density
  ───────────────────────────────────────────────────────────────────────────── -->
  <Section id="district-insights" border={true}>
    <SectionHeading
      eyebrow="Institutional Visibility"
      heading="Institutional insight beyond assignment completion."
      subheading="Assess provides educators and institutions with deeper visibility into how students reason, articulate, and defend their understanding over time."
    />

    <div class="mt-10 grid gap-3 md:grid-cols-2 lg:grid-cols-3">
      <FeatureCard
        label="Comprehension Trends"
        description="Track how student understanding develops across assignments, units, and terms — not just whether work was submitted."
        dotColor="bg-blue-400"
        accent="assess"
        dense={true}
      />
      <FeatureCard
        label="Articulation Confidence"
        description="See how clearly and confidently students can explain their ideas over time — a meaningful signal of developing fluency."
        dotColor="bg-violet-400"
        accent="assess"
        dense={true}
      />
      <FeatureCard
        label="Engagement Visibility"
        description="Understand how actively students engage with their own reasoning — whether they are thinking carefully or producing surface-level responses."
        dotColor="bg-blue-300"
        accent="assess"
        dense={true}
      />
      <FeatureCard
        label="Reasoning Quality"
        description="Evaluate the depth and coherence of student argument structures across courses, instructors, and grade levels."
        dotColor="bg-indigo-400"
        accent="assess"
        dense={true}
      />
      <FeatureCard
        label="Learning Signals"
        description="Surface meaningful patterns about where comprehension is strong and where it needs attention — at classroom, school, or district level."
        dotColor="bg-emerald-400"
        accent="assess"
        dense={true}
      />
      <FeatureCard
        label="Auditable Records"
        description="Every defense session produces structured, reviewable evidence that supports governance, accountability, and fair academic decisions."
        dotColor="bg-blue-400"
        accent="assess"
        dense={true}
      />
    </div>

    <!-- Audience fit row -->
    <div class="mt-6 grid gap-3 md:grid-cols-3">
      {[
        {
          audience: 'Teachers',
          description: 'Review structured evidence tied directly to student work. Spend less time guessing and more time teaching — without adding heavy process to classroom time.',
        },
        {
          audience: 'Schools & Districts',
          description: 'Deploy with policy-aligned confidence. Get consistent visibility across classrooms, courses, and teams. Support governance with auditable records.',
        },
        {
          audience: 'Higher Education',
          description: 'Validate thesis comprehension, oral defense readiness, and academic articulation across departments with a structured, repeatable workflow.',
        },
      ].map(({ audience, description }) => (
        <div class="rounded-xl border border-blue-300/15 bg-blue-500/5 p-5">
          <div class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-blue-300/60 mb-2">{audience}</div>
          <p class="text-body-sm text-white/60 leading-relaxed">{description}</p>
        </div>
      ))}
    </div>
  </Section>


  <!-- ─────────────────────────────────────────────────────────────────────────
       SECTION 6 — TRUST & COMPLIANCE
  ───────────────────────────────────────────────────────────────────────────── -->
  <Section id="trust" border={true} tight={true}>
    <SectionHeading
      eyebrow="Trust & Compliance"
      heading="Built with institutional trust in mind."
      subheading="Assess is designed for the procurement, policy, and privacy requirements of schools, districts, and higher education institutions."
    />

    <div class="mt-10 grid gap-3 md:grid-cols-3">
      <FeatureCard
        label="Compliance"
        detail="FERPA-aware & COPPA-aware"
        description="Data handling designed with student privacy requirements in mind. Built to support FERPA-aware and COPPA-aware institutional deployments."
        dotColor="bg-indigo-400"
        accent="assess"
        detailColor="text-blue-300/60"
        dense={true}
      />
      <FeatureCard
        label="Authentication & Access"
        detail="Role-based institutional controls"
        description="Modern authentication and institutional access controls. Structured for role-based deployment across teachers, administrators, and district leadership."
        dotColor="bg-blue-300"
        accent="assess"
        detailColor="text-blue-300/60"
        dense={true}
      />
      <FeatureCard
        label="Workflow Integration"
        detail="Designed for real classrooms"
        description="Assess integrates with modern classroom and institutional workflows — not to replace them. Practical, repeatable, and sustainable."
        dotColor="bg-emerald-400"
        accent="assess"
        detailColor="text-blue-300/60"
        dense={true}
      />
    </div>

    <div class="mt-5 rounded-xl border border-white/10 bg-white/[0.04] p-4">
      <p class="text-body-sm text-white/50 leading-relaxed text-center">
        For detailed security documentation, data handling practices, and compliance information, see the{' '}
        <a href="/security" class="text-white/70 underline underline-offset-2 hover:text-white transition-colors">Security & Privacy page</a>
        {' '}or contact us for a Data Processing Agreement.
      </p>
    </div>
  </Section>


  <!-- ─────────────────────────────────────────────────────────────────────────
       SECTION 7 — FINAL CTA
  ───────────────────────────────────────────────────────────────────────────── -->
  <Section id="assess-cta" border={true}>
    <CTABlock
      eyebrow="For Institutions"
      heading="Ready to validate genuine understanding?"
      subheading="See how Retensiq Assess helps institutions validate demonstrated understanding — and bring meaningful visibility into how students reason and articulate their work."
      accent="assess"
    >
      <CTAButton href="https://app.retensiq.com/request-invite" variant="primary">
        Request a Demo
      </CTAButton>
      <CTAButton href="/platform" variant="secondary">
        Explore the Platform
      </CTAButton>
    </CTABlock>

    <div class="mt-6 text-center">
      <p class="text-body-sm text-white/35">
        Looking to prepare as a student?{' '}
        <a href="/prep" class="text-white/55 hover:text-white underline underline-offset-2 transition-colors">
          Explore Retensiq Prep →
        </a>
      </p>
    </div>
  </Section>

</BaseLayout>
