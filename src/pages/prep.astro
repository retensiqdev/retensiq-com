---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTAButton from '../components/CTAButton.astro';
import CTABlock from '../components/CTABlock.astro';
import FeatureCard from '../components/FeatureCard.astro';
import SplitLayout from '../components/SplitLayout.astro';
import ProductEyebrow from '../components/ProductEyebrow.astro';

const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Retensiq Prep',
  applicationCategory: 'EducationApplication',
  operatingSystem: 'Web, iOS',
  description:
    'Rehearsal and articulation practice that builds confidence for presentations, oral defenses, and high-stakes academic moments.',
  url: 'https://retensiq.com/prep',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};
---

<BaseLayout
  title="Retensiq Prep"
  description="Retensiq Prep helps students build genuine understanding through rehearsal, articulation practice, and active recall — so they can confidently explain and defend what they know."
  canonicalUrl="https://retensiq.com/prep"
  jsonLd={softwareAppSchema}
>

  <!-- ─────────────────────────────────────────────────────────────────────────
       HERO — conversational, aspirational, mobile-first feel
       Wide rehearsal mockup below headline (full width, more breathing room)
  ───────────────────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden py-24 md:py-36 border-b border-white/8">

    <!-- Softer, warmer ambient glow — emerald, top-left -->
    <div class="pointer-events-none absolute -top-48 -left-48 w-[600px] h-[600px] bg-emerald-600/12 blur-3xl rounded-full" aria-hidden="true"></div>
    <div class="pointer-events-none absolute bottom-0 right-0 w-[400px] h-[400px] bg-emerald-500/5 blur-3xl rounded-full" aria-hidden="true"></div>

    <div class="relative max-w-site mx-auto px-4 sm:px-6">

      <!-- Eyebrow -->
      <div class="prep-fade" style="animation-delay: 0s">
        <ProductEyebrow product="prep" />
      </div>

      <!-- Headline -->
      <h1
        class="text-page-hero font-semibold tracking-tight text-white leading-[1.08] max-w-prose-lg prep-fade"
        style="animation-delay: 0.06s"
      >
        Learn it. Explain it.<br />
        <span class="text-emerald-300/80">Own it.</span>
      </h1>

      <!-- Subheadline — no "AI-" language -->
      <p
        class="mt-6 text-body-lg text-white/65 leading-relaxed max-w-prose prep-fade"
        style="animation-delay: 0.12s"
      >
        Retensiq Prep helps you research, prepare, rehearse, and confidently present what you
        know — through structured articulation and retention practice.
      </p>

      <!-- CTAs -->
      <div
        class="mt-8 flex flex-wrap items-center gap-3 prep-fade"
        style="animation-delay: 0.18s"
      >
        <CTAButton href="https://app.retensiq.com/" variant="primary">
          Get Started Free
        </CTAButton>
        <CTAButton href="https://app.retensiq.com/" variant="secondary">
          Try on Web
        </CTAButton>
      </div>

      <!-- Hero conversational rehearsal mockup — more breathing room, softer borders -->
      <div class="mt-20 prep-rise">
        <div class="rounded-3xl border border-emerald-300/15 bg-emerald-500/[0.04] p-1 shadow-soft">
          <div class="rounded-[20px] border border-white/6 bg-slate-900/80 p-6 md:p-8">

            <!-- Mockup header -->
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-2.5">
                <div class="h-2 w-2 rounded-full bg-emerald-400"></div>
                <span class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/40">Rehearsal Session</span>
              </div>
              <div class="flex items-center gap-3">
                <span class="text-caption text-white/30">Session 3 of 5 · 18 min</span>
                <span class="text-caption font-semibold text-emerald-300/70 bg-emerald-500/15 border border-emerald-300/15 rounded-full px-2.5 py-0.5">Active</span>
              </div>
            </div>

            <!-- 3-column mockup grid — stacks on mobile -->
            <div class="grid gap-3 md:grid-cols-3">

              <div class="rounded-2xl border border-white/8 bg-white/[0.04] p-4">
                <p class="text-caption text-white/40 mb-2">Topic</p>
                <p class="text-body-sm font-medium text-white/85 leading-snug">Climate Policy & Economic Trade-offs</p>
                <div class="mt-3 flex flex-wrap gap-1.5">
                  {['3 sources', '7 claims', '2 sessions'].map((tag) => (
                    <span class="text-caption text-white/35 bg-white/5 border border-white/8 rounded-full px-2 py-0.5">{tag}</span>
                  ))}
                </div>
              </div>

              <div class="rounded-2xl border border-emerald-300/12 bg-emerald-500/6 p-4">
                <p class="text-caption text-emerald-300/60 mb-2">Prep asks</p>
                <p class="text-body-sm text-white/80 leading-relaxed">Walk me through your core argument — as if explaining it to someone who disagrees.</p>
              </div>

              <div class="rounded-2xl border border-white/8 bg-white/[0.04] p-4">
                <p class="text-caption text-white/40 mb-2">Your response</p>
                <p class="text-body-sm text-white/70 leading-relaxed">The economic case for delay is weaker than it looks — short-term costs are front-loaded, but structural savings compound...</p>
                <div class="mt-3 flex items-center gap-2">
                  <div class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse flex-shrink-0"></div>
                  <div class="flex items-end gap-px h-4 flex-1">
                    {[35, 70, 50, 90, 60, 45, 80, 55, 75, 40, 65, 85, 50, 70, 45].map((h, i) => (
                      <div
                        class="flex-1 rounded-full bg-emerald-400/55 prep-bar"
                        style={`height: ${h}%; animation-delay: ${i * 0.06}s`}
                      ></div>
                    ))}
                  </div>
                  <span class="text-caption text-white/30 flex-shrink-0">Speaking</span>
                </div>
              </div>

            </div>

            <!-- Mockup footer -->
            <div class="mt-5 pt-4 border-t border-white/6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
              <div class="flex items-center gap-3 text-caption text-white/35">
                <span>Articulation confidence</span>
                <div class="h-1 w-24 bg-white/8 rounded-full overflow-hidden">
                  <div class="h-full w-[72%] bg-emerald-400/65 rounded-full"></div>
                </div>
                <span class="text-emerald-300/60 font-medium">72% — Improving</span>
              </div>
              <div class="text-caption text-white/30">Next: follow-up questioning</div>
            </div>

          </div>
        </div>
      </div>

    </div>
  </section>

  <style>
    /* ── Hero entrance animations ────────────────────────────────── */
    .prep-fade {
      opacity: 0;
      transform: translateY(10px);
      animation: prep-fade-in 0.5s ease forwards;
    }

    .prep-rise {
      opacity: 0;
      transform: translateY(20px);
      animation: prep-fade-in 0.65s ease forwards 0.28s;
    }

    @keyframes prep-fade-in {
      to { opacity: 1; transform: translateY(0); }
    }

    /* ── Voice waveform bars ─────────────────────────────────────── */
    .prep-wave {
      animation: prep-wave-pulse 1.1s ease-in-out infinite alternate;
    }
    @keyframes prep-wave-pulse {
      from { opacity: 0.25; transform: scaleY(0.5); }
      to   { opacity: 0.75; transform: scaleY(1); }
    }

    /* ── Hero response voice bars ────────────────────────────────── */
    .prep-bar {
      animation: prep-bar-bounce 0.75s ease-in-out infinite alternate;
    }
    @keyframes prep-bar-bounce {
      from { opacity: 0.35; transform: scaleY(0.6); }
      to   { opacity: 0.90; transform: scaleY(1); }
    }
  </style>


  <!-- ─────────────────────────────────────────────────────────────────────────
       SECTION 2 — WHY PREP WORKS
       Learning philosophy — spacious, conversational
  ───────────────────────────────────────────────────────────────────────────── -->
  <Section id="why-prep-works">
    <SplitLayout align="start">
      <!-- Left: philosophy copy -->
      <div>
        <SectionHeading
          eyebrow="Why It Works"
          heading="Passive studying fades. Articulation sticks."
          subheading="Understanding improves when you explain what you know. Rehearsal doesn't just reinforce memory — it reveals gaps, builds fluency, and creates confidence that holds."
        />

        <div class="mt-8 space-y-6">
          {[
            {
              label: 'Explanation strengthens understanding',
              description: 'When you articulate an idea — not just recognize it — you build understanding that holds up in a presentation, defense, or exam. Recognition is not the same as fluency.',
            },
            {
              label: 'Rehearsal reveals what you don\'t know',
              description: 'Practicing articulation exposes gaps that passive review conceals. You find out where your understanding is thin before it matters.',
            },
            {
              label: 'Confidence follows preparation',
              description: 'The anxiety before a presentation isn\'t about the audience — it\'s about not knowing whether you can explain what you know. Prep solves that.',
            },
          ].map(({ label, description }) => (
            <div class="flex gap-4">
              <div class="flex-shrink-0 mt-1.5 h-1.5 w-1.5 rounded-full bg-emerald-400/70"></div>
              <div>
                <div class="text-body-sm font-semibold text-white mb-1.5">{label}</div>
                <p class="text-body-sm text-white/60 leading-relaxed">{description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: passive vs active contrast card — softer Prep style -->
      <div slot="visual" class="rounded-3xl border border-white/8 bg-white/[0.04] p-7 shadow-soft">
        <p class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/35 mb-6">Two approaches to learning</p>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/30 mb-4">Passive Review</p>
            <ul class="space-y-3">
              {[
                'Re-reading notes',
                'Recognition, not recall',
                'Fades under pressure',
                'No articulation practice',
                'Confidence is fragile',
              ].map((item) => (
                <li class="flex items-start gap-2.5 text-body-sm text-white/40">
                  <span class="mt-1.5 h-1 w-1 rounded-full bg-white/20 flex-shrink-0" aria-hidden="true"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

          <div class="rounded-2xl border border-emerald-300/15 bg-emerald-500/6 p-4">
            <p class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-emerald-300/70 mb-4">Active Rehearsal</p>
            <ul class="space-y-3">
              {[
                'Explain in your own words',
                'Recall and articulate',
                'Holds under pressure',
                'Builds real fluency',
                'Confidence is earned',
              ].map((item) => (
                <li class="flex items-start gap-2.5 text-body-sm text-white/80">
                  <span class="mt-1.5 h-1 w-1 rounded-full bg-emerald-400/70 flex-shrink-0" aria-hidden="true"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <div class="mt-6 pt-5 border-t border-white/8">
          <p class="text-body-sm text-white/40 leading-relaxed italic">
            "Retrieval practice — being required to recall and explain what you've learned — produces significantly better long-term retention than restudying."
          </p>
          <p class="mt-1.5 text-caption text-white/25">Learning science research basis</p>
        </div>
      </div>
    </SplitLayout>
  </Section>


  <!-- ─────────────────────────────────────────────────────────────────────────
       SECTION 3 — HOW PREP WORKS
       4-step workflow + preparation workspace mockup
  ───────────────────────────────────────────────────────────────────────────── -->
  <Section id="how-prep-works" border={true}>
    <SplitLayout align="start">
      <!-- Left: workflow steps -->
      <div>
        <SectionHeading
          eyebrow="How It Works"
          heading="Practice until you can explain it naturally."
          subheading="Prep follows the arc of genuine preparation — not passive consumption. Each step moves you closer to understanding you can actually defend."
        />

        <div class="mt-8 space-y-5">
          {[
            {
              step: '01',
              label: 'Create a Topic',
              body: 'Start with a topic, presentation, paper, or subject you want to understand more deeply. Give Prep the context it needs to guide you.',
            },
            {
              step: '02',
              label: 'Build Understanding',
              body: 'Gather sources, summaries, notes, and supporting ideas into a structured preparation workspace. Engage actively — not just read.',
            },
            {
              step: '03',
              label: 'Rehearse & Explain',
              body: 'Practice explaining concepts through conversational rehearsal and guided questioning. Speak, respond, refine. Repeat until it\'s natural.',
            },
            {
              step: '04',
              label: 'Present with Confidence',
              body: 'Strengthen retention, improve articulation, and walk into your presentation, defense, or discussion knowing you\'ve already done this.',
            },
          ].map(({ step, label, body }) => (
            <div class="flex gap-5">
              <div class="flex-shrink-0 w-8 h-8 rounded-xl bg-emerald-500/8 border border-emerald-300/15 flex items-center justify-center text-caption font-semibold text-emerald-300/60">
                {step}
              </div>
              <div>
                <div class="text-body-sm font-semibold text-white mb-1.5">{label}</div>
                <p class="text-body-sm text-white/60 leading-relaxed">{body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: preparation workspace mockup -->
      <div slot="visual" class="rounded-3xl border border-emerald-300/15 bg-emerald-500/[0.04] p-6 shadow-soft">

        <div class="rounded-2xl border border-white/8 bg-slate-900/60 p-4 mb-4">
          <div class="flex items-center gap-2.5 mb-3">
            <div class="h-1.5 w-1.5 rounded-full bg-emerald-400"></div>
            <p class="text-body-sm text-white/50 font-medium">Topic: Keynesian Economics — Thesis Defense</p>
          </div>
          <div class="flex gap-2 flex-wrap">
            {['3 sources', '7 key claims', '2 sessions', 'Oral defense'].map((tag) => (
              <span class="text-caption text-emerald-300/60 bg-emerald-500/8 border border-emerald-300/12 rounded-full px-2.5 py-0.5">
                {tag}
              </span>
            ))}
          </div>
        </div>

        <div class="space-y-3 text-body-sm">
          <div class="rounded-xl border border-white/8 bg-white/[0.04] p-3.5">
            <p class="text-caption text-white/40 mb-1.5">Prep asks</p>
            <p class="text-white/80">Explain why Keynesian stimulus works differently in a liquidity trap.</p>
          </div>

          <div class="rounded-xl border border-emerald-300/15 bg-emerald-500/8 p-3.5">
            <p class="text-caption text-white/40 mb-1.5">You respond</p>
            <p class="text-white/70">In a liquidity trap, monetary policy loses traction because interest rates hit zero — so fiscal stimulus becomes the primary lever for demand management...</p>
          </div>

          <div class="rounded-xl border border-white/8 bg-white/[0.04] p-3.5">
            <p class="text-caption text-white/40 mb-1.5">Follow-up</p>
            <p class="text-white/80">What historical evidence supports fiscal policy effectiveness in that specific context?</p>
          </div>
        </div>

        <div class="mt-4 pt-4 border-t border-white/8">
          <div class="flex justify-between items-center text-caption text-white/40 mb-2">
            <span>Articulation strength</span>
            <span class="text-emerald-300/60 font-medium">Improving</span>
          </div>
          <div class="h-1.5 bg-white/8 rounded-full overflow-hidden">
            <div class="h-full w-[68%] bg-emerald-400/65 rounded-full"></div>
          </div>
        </div>

      </div>
    </SplitLayout>
  </Section>


  <!-- ─────────────────────────────────────────────────────────────────────────
       SECTION 4 — CONVERSATIONAL REHEARSAL
       Core differentiator — voice-first, app-like
  ───────────────────────────────────────────────────────────────────────────── -->
  <Section id="conversational-rehearsal" border={true}>
    <SplitLayout align="center" reverse={true}>

      <!-- Left (visual): voice interaction mockup -->
      <div slot="visual" class="rounded-3xl border border-emerald-300/15 bg-emerald-500/[0.04] p-6 shadow-soft">

        <div class="rounded-2xl border border-white/8 bg-slate-900/60 p-5 mb-4">
          <div class="flex items-center justify-between mb-4">
            <p class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/40">Voice Rehearsal</p>
            <div class="flex items-center gap-1.5">
              <div class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></div>
              <span class="text-caption text-emerald-300/60 font-medium">Recording</span>
            </div>
          </div>

          <!-- Voice waveform -->
          <div class="flex items-end justify-center gap-px h-10 mb-5 px-2">
            {[25, 55, 38, 72, 88, 58, 42, 78, 62, 48, 82, 68, 38, 58, 32, 52, 42, 68, 52, 62, 45, 75, 55, 40].map((h, i) => (
              <div
                class="flex-1 rounded-full bg-emerald-400/50 prep-wave"
                style={`height: ${h}%; animation-delay: ${i * 0.07}s`}
              ></div>
            ))}
          </div>

          <div class="space-y-2.5 text-body-sm">
            <div class="rounded-xl border border-white/6 bg-white/[0.04] p-3">
              <p class="text-caption text-white/35 mb-1.5">Challenge</p>
              <p class="text-white/75">What would have to be true for your argument to fail? What's your weakest assumption?</p>
            </div>
            <div class="rounded-xl border border-emerald-300/12 bg-emerald-500/6 p-3">
              <p class="text-caption text-white/35 mb-1.5">Your response</p>
              <p class="text-white/65">If the longitudinal data showed no correlation after controlling for confounds, I'd have to reconsider the causal claim — but the mechanism is independently supported by...</p>
            </div>
          </div>

          <div class="mt-4 pt-4 border-t border-white/8 grid grid-cols-3 gap-2 text-center">
            {[
              { label: 'Argument clarity', score: 'Strong' },
              { label: 'Evidence use', score: 'Specific' },
              { label: 'Adaptability', score: 'Good' },
            ].map(({ label, score }) => (
              <div>
                <div class="text-caption text-white/30 mb-1">{label}</div>
                <div class="text-caption font-semibold text-emerald-300/70">{score}</div>
              </div>
            ))}
          </div>
        </div>

        <img
          src="/images/sa-voice-recording.png"
          alt="Voice rehearsal interface showing a student practicing articulation"
          class="w-full rounded-2xl border border-white/8"
          loading="lazy"
        />

      </div>

      <!-- Right: narrative copy -->
      <div>
        <SectionHeading
          eyebrow="Conversational Rehearsal"
          heading="Practice articulation in real conversations."
          subheading="Prep doesn't just quiz you. It guides you through the kind of explanation and defense that builds genuine fluency — not surface-level recall."
        />

        <div class="mt-8 space-y-6">
          {[
            {
              label: 'Guided explanation practice',
              description: 'Prep asks you to explain ideas in your own words — then follows up, challenges your reasoning, and pushes for clarity and specificity. It\'s practice, not just review.',
            },
            {
              label: 'Structured challenge questioning',
              description: 'Interactive questioning reveals weak spots in your understanding before a presentation, exam, or oral defense can surface them first. You find the gaps. Not your audience.',
            },
            {
              label: 'Voice-first and conversational',
              description: 'Respond by voice or text. The experience is designed to feel like genuine preparation — not a test, not a quiz, not a chatbot. A rehearsal partner.',
            },
          ].map(({ label, description }) => (
            <div class="flex gap-4">
              <div class="flex-shrink-0 mt-1.5 h-1.5 w-1.5 rounded-full bg-emerald-400/70"></div>
              <div>
                <div class="text-body-sm font-semibold text-white mb-1.5">{label}</div>
                <p class="text-body-sm text-white/60 leading-relaxed">{description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </SplitLayout>
  </Section>


  <!-- ─────────────────────────────────────────────────────────────────────────
       SECTION 5 — USE CASES
       5 cards + positioning anchor — generous spacing, Prep style
  ───────────────────────────────────────────────────────────────────────────── -->
  <Section id="use-cases" border={true}>
    <SectionHeading
      eyebrow="Use Cases"
      heading="Designed for moments that matter."
      subheading="Wherever you need to explain and defend what you know — Prep helps you arrive ready."
    />

    <div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      <FeatureCard
        label="Presentation Preparation"
        description="Practice presenting ideas clearly and confidently before class, meetings, or public speaking situations. Rehearse until explanation feels natural."
        dotColor="bg-emerald-400"
        accent="prep"
      />
      <FeatureCard
        label="Oral Defense"
        description="Rehearse defending papers, projects, and arguments through guided questioning. Prepare for follow-up challenges before they happen in the room."
        dotColor="bg-teal-400"
        accent="prep"
      />
      <FeatureCard
        label="Studying & Retention"
        description="Strengthen retention through active explanation and rehearsal instead of passive re-reading. Recall improves when you articulate — not just recognize."
        dotColor="bg-emerald-300"
        accent="prep"
      />
      <FeatureCard
        label="Debate & Argumentation"
        description="Improve articulation, reasoning, and structured argument development. Practice responding to counterarguments and refining your position under pressure."
        dotColor="bg-cyan-400"
        accent="prep"
      />
      <FeatureCard
        label="Thesis & Capstone Preparation"
        description="Prepare for high-stakes presentations and defense situations with structured rehearsal. Walk in having already defended your work multiple times."
        dotColor="bg-emerald-500"
        accent="prep"
      />

      <!-- Positioning anchor card -->
      <div class="rounded-3xl border border-emerald-300/8 bg-emerald-500/[0.03] p-6">
        <p class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-emerald-300/40 mb-3">What they share</p>
        <p class="text-body-sm text-white/40 leading-relaxed italic">
          Each of these moments rewards one thing above all else: the ability to confidently explain and defend what you know.
        </p>
      </div>
    </div>
  </Section>


  <!-- ─────────────────────────────────────────────────────────────────────────
       SECTION 6 — MOBILE-FIRST EXPERIENCE
       Phone-frame signature element for Prep
  ───────────────────────────────────────────────────────────────────────────── -->
  <Section id="mobile-first" border={true}>
    <SplitLayout align="center">
      <!-- Left: copy + CTAs -->
      <div>
        <SectionHeading
          eyebrow="Mobile-First"
          heading="Preparation that fits into real life."
          subheading="Prep is designed for how people actually prepare — in short focused sessions, on the go, wherever you have a few minutes to rehearse."
        />

        <div class="mt-8 space-y-5">
          {[
            {
              label: 'Between classes, on a walk, during a commute',
              description: 'Use Prep during short study sessions, presentation practice, or any focused rehearsal window. Practice doesn\'t require a desk.',
            },
            {
              label: 'Voice-first when you need it',
              description: 'Speak your responses naturally. Prep is built around conversational interaction — not typing-heavy forms or complex interfaces.',
            },
            {
              label: 'Pick up where you left off',
              description: 'Each session builds on the last. Prep tracks your rehearsal progress and surfaces the areas that still need work.',
            },
          ].map(({ label, description }) => (
            <div class="flex gap-4">
              <div class="flex-shrink-0 mt-1.5 h-1.5 w-1.5 rounded-full bg-emerald-400/70"></div>
              <div>
                <div class="text-body-sm font-semibold text-white mb-1.5">{label}</div>
                <p class="text-body-sm text-white/60 leading-relaxed">{description}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          <CTAButton href="https://app.retensiq.com/" variant="primary">
            Get Started Free
          </CTAButton>
          <CTAButton href="https://app.retensiq.com/" variant="secondary">
            Try on Web
          </CTAButton>
        </div>
      </div>

      <!-- Right: phone frame mockup — Prep signature element -->
      <div slot="visual" class="flex items-center justify-center py-4">
        <div class="relative w-52 md:w-60">

          <!-- Subtle glow behind phone -->
          <div class="absolute inset-0 -m-8 bg-emerald-500/8 blur-3xl rounded-full pointer-events-none" aria-hidden="true"></div>

          <!-- Phone shell -->
          <div class="relative rounded-[2.75rem] border-[3px] border-white/12 bg-slate-900 shadow-soft overflow-hidden">

            <!-- Dynamic island / notch bar -->
            <div class="flex justify-center pt-3.5 pb-2 bg-slate-900">
              <div class="w-24 h-[18px] bg-slate-800 rounded-full"></div>
            </div>

            <!-- Screen -->
            <div class="bg-slate-950 px-3 pb-7 space-y-2.5">

              <!-- App bar -->
              <div class="flex items-center justify-between py-2.5 border-b border-white/6">
                <div class="flex items-center gap-1.5">
                  <div class="h-1.5 w-1.5 rounded-full bg-emerald-400"></div>
                  <span class="text-white/60 font-semibold uppercase tracking-widest" style="font-size: 9px">Retensiq Prep</span>
                </div>
                <span class="text-white/25" style="font-size: 9px">Session 2</span>
              </div>

              <!-- Prep question bubble -->
              <div class="rounded-xl border border-emerald-300/12 bg-emerald-500/6 p-2.5">
                <p class="text-white/50 mb-1" style="font-size: 8px">Prep asks</p>
                <p class="text-white/85 leading-relaxed" style="font-size: 10px">Summarize your central argument in one sentence.</p>
              </div>

              <!-- Mic button -->
              <div class="flex justify-center py-2">
                <div class="h-11 w-11 rounded-full border-2 border-emerald-400/35 bg-emerald-500/10 flex items-center justify-center">
                  <div class="h-5 w-5 rounded-full bg-emerald-400/65"></div>
                </div>
              </div>

              <!-- Response bubble -->
              <div class="rounded-xl border border-white/6 bg-white/[0.04] p-2.5">
                <p class="text-white/45 mb-1.5" style="font-size: 8px">Your response</p>
                <p class="text-white/70 leading-relaxed" style="font-size: 10px">My argument is that early intervention reduces long-term costs by...</p>
                <div class="flex items-end gap-px h-2.5 mt-2">
                  {[40, 70, 55, 85, 60, 45, 75, 50, 65, 80, 45, 60, 38, 70, 52].map((h) => (
                    <div class="flex-1 rounded-full bg-emerald-400/40" style={`height: ${h}%`}></div>
                  ))}
                </div>
              </div>

              <!-- Status row -->
              <div class="flex justify-between items-center pt-1 border-t border-white/6">
                <span class="text-white/25" style="font-size: 8px">2 of 5 questions</span>
                <span class="text-emerald-300/50 font-semibold" style="font-size: 8px">↑ Improving</span>
              </div>

            </div>
          </div>

          <!-- Home indicator -->
          <div class="flex justify-center mt-2.5">
            <div class="w-20 h-[3px] bg-white/12 rounded-full"></div>
          </div>

        </div>
      </div>
    </SplitLayout>
  </Section>


  <!-- ─────────────────────────────────────────────────────────────────────────
       SECTION 7 — FINAL CTA
  ───────────────────────────────────────────────────────────────────────────── -->
  <Section id="prep-cta" border={true}>
    <CTABlock
      eyebrow="For Students"
      heading="Prepare with confidence."
      subheading="Strengthen understanding through rehearsal, explanation, and active recall. Prep helps you arrive ready — for presentations, defenses, and the moments that matter."
      accent="prep"
    >
      <CTAButton href="https://app.retensiq.com/" variant="primary">
        Get Started Free
      </CTAButton>
      <CTAButton href="https://app.retensiq.com/" variant="secondary">
