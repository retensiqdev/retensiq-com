---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CTAButton from '../components/CTAButton.astro';
import CTABlock from '../components/CTABlock.astro';
import FeatureCard from '../components/FeatureCard.astro';
import SplitLayout from '../components/SplitLayout.astro';
---

<BaseLayout
  title="Retensiq"
  description="Retensiq helps institutions validate genuine understanding and helps students develop the articulation and retention that make knowledge last."
>

  <!-- ─────────────────────────────────────────────────────────────────────────
       HERO — two-column: headline + routing CTAs / animated workflow visual
  ───────────────────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden py-24 md:py-36 border-b border-white/10">

    <!-- Restrained radial gradient — single ambient light, no blob soup -->
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_50%_-10%,rgba(99,102,241,0.10),transparent)]" aria-hidden="true"></div>

    <div class="max-w-site mx-auto px-4 sm:px-6 relative">
      <div class="grid gap-16 lg:grid-cols-2 lg:items-center">

        <!-- Left: text + CTAs -->
        <div>
          <p class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/35 mb-5">
            Developing, Validating, and Defending Understanding
          </p>
          <h1 class="text-hero font-semibold tracking-tight text-white leading-[1.05]">
            Retention,<br />Proven.
          </h1>
          <p class="mt-6 text-body-lg text-white/65 leading-relaxed max-w-prose">
            A platform for developing, validating, and defending genuine understanding — for the institutions that assess it and the students who build it.
          </p>

          <!-- Audience routing CTAs — equal visual weight -->
          <div class="mt-10 flex flex-col sm:flex-row gap-3">
            <CTAButton href="/assess" variant="primary">
              For Schools &amp; Institutions
            </CTAButton>
            <CTAButton href="/prep" variant="secondary">
              For Students
            </CTAButton>
          </div>
        </div>

        <!-- Right: SVG workflow visualization (desktop only) -->
        <div class="hidden lg:flex items-center justify-center" aria-hidden="true">
          <div class="hero-visual w-full max-w-sm">
            <svg viewBox="0 0 320 360" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
              <!-- Vertical connecting spine -->
              <line x1="40" y1="48" x2="40" y2="312"
                stroke="rgba(255,255,255,0.08)" stroke-width="1.5" stroke-dasharray="4 4"
                class="spine-line" />

              <!-- Stage 1: Research -->
              <g class="stage stage-1">
                <circle cx="40" cy="48" r="6" fill="rgba(99,102,241,0.7)" />
                <rect x="64" y="28" width="220" height="40" rx="10"
                  fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.10)" stroke-width="1"/>
                <text x="80" y="44" fill="rgba(255,255,255,0.90)" font-size="11" font-weight="600" font-family="Inter,system-ui,sans-serif">Research</text>
                <text x="80" y="58" fill="rgba(255,255,255,0.40)" font-size="9.5" font-family="Inter,system-ui,sans-serif">Gather sources, notes, and evidence.</text>
              </g>
              <circle cx="40" cy="112" r="2.5" fill="rgba(255,255,255,0.15)" class="connector-dot" />

              <!-- Stage 2: Develop -->
              <g class="stage stage-2">
                <circle cx="40" cy="144" r="6" fill="rgba(139,92,246,0.7)" />
                <rect x="64" y="124" width="220" height="40" rx="10"
                  fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.10)" stroke-width="1"/>
                <text x="80" y="140" fill="rgba(255,255,255,0.90)" font-size="11" font-weight="600" font-family="Inter,system-ui,sans-serif">Develop</text>
                <text x="80" y="154" fill="rgba(255,255,255,0.40)" font-size="9.5" font-family="Inter,system-ui,sans-serif">Structure reasoning and understanding.</text>
              </g>
              <circle cx="40" cy="208" r="2.5" fill="rgba(255,255,255,0.15)" class="connector-dot" />

              <!-- Stage 3: Rehearse -->
              <g class="stage stage-3">
                <circle cx="40" cy="240" r="6" fill="rgba(16,185,129,0.7)" />
                <rect x="64" y="220" width="220" height="40" rx="10"
                  fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.10)" stroke-width="1"/>
                <text x="80" y="236" fill="rgba(255,255,255,0.90)" font-size="11" font-weight="600" font-family="Inter,system-ui,sans-serif">Rehearse</text>
                <text x="80" y="250" fill="rgba(255,255,255,0.40)" font-size="9.5" font-family="Inter,system-ui,sans-serif">Strengthen articulation through practice.</text>
              </g>
              <circle cx="40" cy="304" r="2.5" fill="rgba(255,255,255,0.15)" class="connector-dot" />

              <!-- Stage 4: Present -->
              <g class="stage stage-4">
                <circle cx="40" cy="336" r="6" fill="rgba(245,158,11,0.7)" />
                <rect x="64" y="316" width="220" height="40" rx="10"
                  fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.10)" stroke-width="1"/>
                <text x="80" y="332" fill="rgba(255,255,255,0.90)" font-size="11" font-weight="600" font-family="Inter,system-ui,sans-serif">Present</text>
                <text x="80" y="346" fill="rgba(255,255,255,0.40)" font-size="9.5" font-family="Inter,system-ui,sans-serif">Demonstrate comprehension with clarity.</text>
              </g>
            </svg>
          </div>
        </div>

      </div>
    </div>
  </section>

  <style>
    .stage {
      opacity: 0;
      animation: stage-appear 0.5s ease forwards;
    }
    .stage-1 { animation-delay: 0.10s; }
    .stage-2 { animation-delay: 0.35s; }
    .stage-3 { animation-delay: 0.60s; }
    .stage-4 { animation-delay: 0.85s; }

    .connector-dot {
      opacity: 0;
      animation: stage-appear 0.3s ease forwards;
    }
    .stage-1 + .connector-dot { animation-delay: 0.28s; }
    .stage-2 + .connector-dot { animation-delay: 0.53s; }
    .stage-3 + .connector-dot { animation-delay: 0.78s; }

    @keyframes stage-appear {
      from { opacity: 0; transform: translateX(-6px); }
      to   { opacity: 1; transform: translateX(0); }
    }

    .spine-line {
      stroke-dashoffset: 400;
      animation: draw-spine 1.2s ease forwards 0.05s;
    }
    @keyframes draw-spine {
      to { stroke-dashoffset: 0; }
    }
  </style>


  <!-- ─────────────────────────────────────────────────────────────────────────
       SECTION 2 — SHARED WORKFLOW NARRATIVE
       Four connected stages — the philosophy that unifies both products
  ───────────────────────────────────────────────────────────────────────────── -->
  <Section id="workflow" border={true}>
    <SectionHeading
      eyebrow="Shared Philosophy"
      heading="Research. Develop. Rehearse. Present."
      subheading="Genuine understanding isn't tested once — it's built. Retensiq supports the full arc of how people develop, practice, and defend what they know."
      maxWidth="max-w-prose-lg"
      center={true}
    />

    <div class="mt-14 relative">
      <!-- Horizontal connector line (desktop only) -->
      <div class="hidden md:block absolute top-[2.1rem] left-[calc(12.5%+1rem)] right-[calc(12.5%+1rem)] h-px bg-white/8" aria-hidden="true"></div>

      <div class="grid grid-cols-1 gap-0 md:grid-cols-4 md:gap-4">
        {[
          {
            step: '01',
            label: 'Research',
            description: 'Gather sources, summaries, notes, and supporting evidence.',
            color: 'bg-indigo-400',
          },
          {
            step: '02',
            label: 'Develop',
            description: 'Transform research into structured reasoning and defendable understanding.',
            color: 'bg-violet-400',
          },
          {
            step: '03',
            label: 'Rehearse',
            description: 'Strengthen articulation through guided rehearsal and active recall.',
            color: 'bg-emerald-400',
          },
          {
            step: '04',
            label: 'Present',
            description: 'Demonstrate understanding through explanation, presentation, and oral defense.',
            color: 'bg-amber-400',
          },
        ].map(({ step, label, description, color }) => (
          <div class="relative flex md:flex-col gap-4 md:gap-0 py-5 md:py-0 border-l-2 md:border-l-0 border-white/8 pl-5 md:pl-0 ml-3 md:ml-0">
            <!-- Mobile: vertical spine dot -->
            <div class:list={['md:hidden absolute -left-[7px] top-[1.6rem] w-3 h-3 rounded-full flex-shrink-0', color]} aria-hidden="true"></div>

            <!-- Step node (desktop: centered top) -->
            <div class="relative z-10 flex md:justify-center mb-0 md:mb-4">
              <div class:list={['w-3 h-3 rounded-full flex-shrink-0 hidden md:block mt-1', color]}></div>
            </div>

            <div class="md:rounded-2xl md:border md:border-white/10 md:bg-white/[0.04] md:p-5 flex-1">
              <div class="text-caption font-semibold text-white/30 mb-2">{step}</div>
              <div class="text-body font-semibold text-white mb-2">{label}</div>
              <p class="text-caption text-white/55 leading-relaxed">{description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Section>


  <!-- ─────────────────────────────────────────────────────────────────────────
       SECTION 3 — CATEGORY REFRAME
       Repositions away from AI detection toward demonstrated understanding
  ───────────────────────────────────────────────────────────────────────────── -->
  <Section id="category-reframe" border={true}>
    <SectionHeading
      eyebrow="The Problem"
      heading="Submissions don't prove understanding."
      subheading="Traditional systems evaluate outputs. Retensiq evaluates how well students can explain, defend, and reason through their work."
      maxWidth="max-w-prose-lg"
      center={true}
    />

    <div class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-3">

      <!-- Traditional AI Detection -->
      <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-6">
        <p class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/35 mb-4">Traditional Detection</p>
        <ul class="space-y-3">
          {['Flags probability', 'Evaluates output', 'Reactive'].map((item) => (
            <li class="flex items-start gap-2.5 text-body-sm text-white/50">
              <span class="mt-1.5 h-1 w-1 rounded-full bg-white/20 flex-shrink-0" aria-hidden="true"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Writing Tools -->
      <div class="rounded-2xl border border-white/10 bg-white/[0.04] p-6">
        <p class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/35 mb-4">Writing Tools</p>
        <ul class="space-y-3">
          {['Generates content', 'Assists writing', 'Generative'].map((item) => (
            <li class="flex items-start gap-2.5 text-body-sm text-white/50">
              <span class="mt-1.5 h-1 w-1 rounded-full bg-white/20 flex-shrink-0" aria-hidden="true"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <!-- Retensiq — accented to differentiate -->
      <div class="rounded-2xl border border-indigo-300/25 bg-indigo-500/5 p-6">
        <p class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-indigo-300/70 mb-4">Retensiq</p>
        <ul class="space-y-3">
          {['Measures understanding', 'Evaluates reasoning', 'Interactive'].map((item) => (
            <li class="flex items-start gap-2.5 text-body-sm text-white/75">
              <span class="mt-1.5 h-1 w-1 rounded-full bg-indigo-400/70 flex-shrink-0" aria-hidden="true"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>

    </div>
  </Section>


  <!-- ─────────────────────────────────────────────────────────────────────────
       SECTION 4 — PRODUCT SPLIT
       Assess (blue) vs Prep (emerald), equal visual weight
  ───────────────────────────────────────────────────────────────────────────── -->
  <Section id="products" border={true}>
    <SectionHeading
      eyebrow="Two Products. One Philosophy."
      heading="Choose your path."
      subheading="Retensiq Assess and Retensiq Prep are purpose-built for their audiences — unified by the same commitment to genuine understanding."
      maxWidth="max-w-prose-lg"
    />

    <div class="mt-12 grid gap-6 md:grid-cols-2 items-stretch">

      <!-- Assess card — institutional blue -->
      <div class="rounded-3xl border border-blue-300/20 bg-blue-500/5 p-8 shadow-soft flex flex-col">
        <div class="flex items-center gap-2 mb-6">
          <span class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-blue-300/70">Retensiq</span>
          <span class="text-caption text-white/25">·</span>
          <span class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/50">Assess</span>
        </div>
        <h2 class="text-xl font-semibold tracking-tight leading-snug text-white">
          Institutional visibility into genuine understanding.
        </h2>
        <p class="mt-4 text-body-sm text-white/60 leading-relaxed flex-grow">
          Retensiq Assess helps institutions validate comprehension through oral defense, reasoning analysis, and articulation-based assessment. Built for districts, schools, and higher education.
        </p>
        <ul class="mt-6 space-y-2.5">
          {[
            'Oral defense and comprehension visibility',
            'Reasoning evaluation and articulation analysis',
            'District-level insights and auditable records',
          ].map((item) => (
            <li class="flex items-start gap-2.5 text-body-sm text-white/60">
              <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-blue-400 flex-shrink-0" aria-hidden="true"></span>
              {item}
            </li>
          ))}
        </ul>
        <div class="mt-8">
          <CTAButton href="/assess" variant="secondary" class="w-full justify-center">
            Explore Assess →
          </CTAButton>
        </div>
      </div>

      <!-- Prep card — conversational emerald -->
      <div class="rounded-3xl border border-emerald-300/20 bg-emerald-500/5 p-8 shadow-soft flex flex-col">
        <div class="flex items-center gap-2 mb-6">
          <span class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-emerald-300/70">Retensiq</span>
          <span class="text-caption text-white/25">·</span>
          <span class="text-eyebrow uppercase tracking-[0.1em] font-semibold text-white/50">Prep</span>
        </div>
        <h2 class="text-xl font-semibold tracking-tight leading-snug text-white">
          Confidence through rehearsal and articulation.
        </h2>
        <p class="mt-4 text-body-sm text-white/60 leading-relaxed flex-grow">
          Retensiq Prep helps students research, prepare, rehearse, and confidently present what they know — through structured articulation and retention practice.
        </p>
        <ul class="mt-6 space-y-2.5">
          {[
            'Rehearsal, active recall, and retention practice',
            'Presentation and oral defense readiness',
            'Confidence through articulation practice',
          ].map((item) => (
            <li class="flex items-start gap-2.5 text-body-sm text-white/60">
              <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-emerald-400 flex-shrink-0" aria-hidden="true"></span>
              {item}
            </li>
          ))}
        </ul>
        <div class="mt-8">
          <CTAButton href="/prep" variant="secondary" class="w-full justify-center">
            Explore Prep →
          </CTAButton>
        </div>
      </div>

    </div>
  </Section>


  <!-- ─────────────────────────────────────────────────────────────────────────
       SECTION 5 — TRUST / PLATFORM
       Centered heading + 3-pillar grid. Restrained, no CTA.
  ───────────────────────────────────────────────────────────────────────────── -->
  <Section id="trust" border={true}>
    <SectionHeading
      eyebrow="Platform"
      heading="Built with institutional trust in mind."
      subheading="Understanding becomes meaningful when it's built on a foundation institutions can rely on."
      maxWidth="max-w-prose-lg"
      center={true}
    />

    <div class="mt-10 grid gap-4 md:grid-cols-3">
      <FeatureCard
        label="Compliance"
        description="FERPA-aware and COPPA-aware data handling by design, built for district procurement and policy requirements."
        dotColor="bg-indigo-400"
      />
      <FeatureCard
        label="Security"
        description="Secure authentication, role-based access controls, and institutional access management."
        dotColor="bg-violet-400"
      />
      <FeatureCard
        label="Integration"
        description="LMS integration, LTI-authenticated access, and workflows built for how classrooms actually operate."
        dotColor="bg-emerald-400"
      />
    </div>
  </Section>


  <!-- ─────────────────────────────────────────────────────────────────────────
       SECTION 6 — FINAL CTA
       Two-column routing back to Assess and Prep
  ───────────────────────────────────────────────────────────────────────────── -->
  <Section id="cta" border={true}>
    <div class="grid gap-6 md:grid-cols-2">

      <CTABlock
        eyebrow="For Institutions"
        heading="Bring Assess to Your Institution"
        accent="assess"
        center={false}
      >
        <CTAButton href="/assess" variant="primary">
          Explore Assess
        </CTAButton>
      </CTABlock>

      <CTABlock
        eyebrow="For Students"
        heading="Start Preparing with Prep"
        accent="prep"
        center={false}
      >
        <CTAButton href="/prep" variant="secondary">
          Explore Prep
        </CTAButton>
      </CTABlock>

    </div>
  </Section>

</BaseLayout>
