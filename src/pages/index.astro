---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTAButton from '../components/CTAButton.astro';

const description =
  "The future of education isn't detecting AI. It's understanding students, supporting teachers, and strengthening conversations.";
const tagline = "We're building something different.";
---

<BaseLayout title="Retensiq" description={description} showHeader={false}>
  <section
    class="relative flex min-h-[100dvh] items-center justify-center overflow-hidden px-4 sm:px-6"
    aria-labelledby="teaser-headline"
  >
    <!-- Ambient gradient -->
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_40%,rgba(99,102,241,0.08),transparent_70%)]"
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_50%_40%_at_80%_20%,rgba(139,92,246,0.05),transparent_60%)]"
      aria-hidden="true"
    ></div>

    <!-- Abstract connection network -->
    <div class="pointer-events-none absolute inset-0 flex items-center justify-center opacity-40" aria-hidden="true">
      <svg
        class="teaser-network h-full w-full max-w-5xl text-white/20"
        viewBox="0 0 800 600"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <circle class="network-node" cx="120" cy="180" r="3" fill="currentColor" />
        <circle class="network-node" cx="280" cy="120" r="2.5" fill="currentColor" />
        <circle class="network-node" cx="520" cy="160" r="3" fill="currentColor" />
        <circle class="network-node" cx="680" cy="220" r="2.5" fill="currentColor" />
        <circle class="network-node" cx="200" cy="380" r="2.5" fill="currentColor" />
        <circle class="network-node" cx="400" cy="420" r="3" fill="currentColor" />
        <circle class="network-node" cx="600" cy="360" r="2.5" fill="currentColor" />
        <circle class="network-node" cx="400" cy="280" r="4" fill="currentColor" opacity="0.6" />

        <line class="network-line" x1="120" y1="180" x2="280" y2="120" stroke="currentColor" stroke-width="0.75" opacity="0.35" />
        <line class="network-line" x1="280" y1="120" x2="520" y2="160" stroke="currentColor" stroke-width="0.75" opacity="0.35" />
        <line class="network-line" x1="520" y1="160" x2="680" y2="220" stroke="currentColor" stroke-width="0.75" opacity="0.35" />
        <line class="network-line" x1="120" y1="180" x2="200" y2="380" stroke="currentColor" stroke-width="0.75" opacity="0.25" />
        <line class="network-line" x1="200" y1="380" x2="400" y2="420" stroke="currentColor" stroke-width="0.75" opacity="0.25" />
        <line class="network-line" x1="400" y1="420" x2="600" y2="360" stroke="currentColor" stroke-width="0.75" opacity="0.25" />
        <line class="network-line" x1="280" y1="120" x2="400" y2="280" stroke="currentColor" stroke-width="0.75" opacity="0.3" />
        <line class="network-line" x1="520" y1="160" x2="400" y2="280" stroke="currentColor" stroke-width="0.75" opacity="0.3" />
        <line class="network-line" x1="400" y1="280" x2="600" y2="360" stroke="currentColor" stroke-width="0.75" opacity="0.3" />
        <line class="network-line" x1="400" y1="280" x2="200" y2="380" stroke="currentColor" stroke-width="0.75" opacity="0.2" />
      </svg>
    </div>

    <!-- Hero content -->
    <div class="relative z-10 mx-auto w-full max-w-3xl text-center">
      <img
        src="/images/logo-white.png"
        alt="Retensiq"
        width="1144"
        height="287"
        class="mx-auto h-auto w-[clamp(16rem,42vw,30rem)]"
      />

      <h1
        id="teaser-headline"
        class="mt-10 sm:mt-12 tracking-tight leading-snug"
      >
        <span class="block text-2xl sm:text-3xl md:text-[2.25rem] font-semibold text-white">
          The future of education isn't detecting AI.
        </span>
        <span class="block mt-3 text-xl sm:text-2xl md:text-[1.75rem] font-medium text-white/70">
          It's understanding students, supporting teachers, and strengthening conversations.
        </span>
      </h1>

      <p class="mx-auto mt-6 text-body-lg text-white/55">{tagline}</p>

      <div class="mt-10 flex flex-col items-center gap-5">
        <CTAButton
          href="https://app.retensiq.com/request-invite/assess"
          variant="primary"
          class="px-8 py-3 text-base min-h-[48px]"
        >
          Request Early Access
        </CTAButton>

        <a
          href="https://app.retensiq.com/"
          rel="noopener noreferrer"
          class="text-body-sm text-white/45 hover:text-white/70 transition-colors underline-offset-4 hover:underline"
        >
          Login
        </a>
      </div>
    </div>
  </section>

  <style>
    @media (prefers-reduced-motion: no-preference) {
      .network-node {
        animation: node-pulse 6s ease-in-out infinite;
      }
      .network-node:nth-child(2) { animation-delay: 0.8s; }
      .network-node:nth-child(3) { animation-delay: 1.6s; }
      .network-node:nth-child(4) { animation-delay: 2.4s; }
      .network-node:nth-child(5) { animation-delay: 3.2s; }
      .network-node:nth-child(6) { animation-delay: 4s; }
      .network-node:nth-child(7) { animation-delay: 4.8s; }
      .network-node:nth-child(8) { animation-delay: 5.6s; }

      .network-line {
        animation: line-fade 8s ease-in-out infinite;
      }
      .network-line:nth-child(9) { animation-delay: 1s; }
      .network-line:nth-child(10) { animation-delay: 2s; }
      .network-line:nth-child(11) { animation-delay: 3s; }
      .network-line:nth-child(12) { animation-delay: 4s; }
      .network-line:nth-child(13) { animation-delay: 5s; }
      .network-line:nth-child(14) { animation-delay: 6s; }
      .network-line:nth-child(15) { animation-delay: 7s; }

      @keyframes node-pulse {
        0%, 100% { opacity: 0.4; }
        50% { opacity: 0.9; }
      }

      @keyframes line-fade {
        0%, 100% { opacity: 0.15; }
        50% { opacity: 0.45; }
      }
    }
  </style>
</BaseLayout>
